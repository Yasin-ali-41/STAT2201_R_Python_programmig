# Question 1(ii): Demonstrate consistency of the sample mean
set.seed(123)
mu <- 20
sigma <- 5
num_sim <- 10000
# Different sample sizes
sample_sizes <- c(10, 50, 100, 250, 500, 750, 1000)
# Vectors to store results
mean_estimates <- numeric(length(sample_sizes))
sd_estimates <- numeric(length(sample_sizes))
# Loop through sample sizes
for (i in seq_along(sample_sizes)) {
n_i <- sample_sizes[i]
means_i <- replicate(num_sim, mean(rnorm(n_i, mean = mu, sd = sigma)))
mean_estimates[i] <- mean(means_i)
sd_estimates[i] <- sd(means_i)
}
# Plot mean estimates with ±2 SD error bars
plot(sample_sizes, mean_estimates, type = "b", pch = 19,
xlab = "Sample Size (n)", ylab = "Mean Estimate",
main = "Consistency of Sample Mean")
arrows(sample_sizes, mean_estimates - 2 * sd_estimates,
sample_sizes, mean_estimates + 2 * sd_estimates,
angle = 90, code = 3, length = 0.05, col = "blue")
abline(h = mu, col = "red", lty = 2)
# Interpretation:
# As n increases, the mean estimates approach the true mean (20),
# and the variability (error bars) decreases.
# This shows the sample mean is a consistent estimator.
set.seed(123)
mu <- 20
sigma <- 5
num_sim <- 10000
# Different sample sizes
sample_sizes <- c(10, 50, 100, 250, 500, 750, 1000)
# Vectors to store results
mean_estimates <- numeric(length(sample_sizes))
sd_estimates <- numeric(length(sample_sizes))
# Loop through sample sizes
for (i in seq_along(sample_sizes)) {
n_i <- sample_sizes[i]
means_i <- replicate(num_sim, mean(rnorm(n_i, mean = mu, sd = sigma)))
mean_estimates[i] <- mean(means_i)
sd_estimates[i] <- sd(means_i)
}
# Plot mean estimates with ±2 SD error bars
plot(sample_sizes, mean_estimates, type = "b", pch = 19,
xlab = "Sample Size (n)", ylab = "Mean Estimate",
main = "Consistency of Sample Mean")
arrows(sample_sizes, mean_estimates - 2 * sd_estimates,
sample_sizes, mean_estimates + 2 * sd_estimates,
angle = 90, code = 3, length = 0.05, col = "blue")
# Question 3(i): Simulate MLE estimates for Normal, Binomial, and Exponential distributions
set.seed(123)
# Parameters
n <- 10000
normal_mean <- 6
binom_p <- 0.7
exp_rate <- 2
# --- Normal Distribution ---
normal_estimates <- replicate(n, mean(rnorm(100, mean = normal_mean, sd = 1)))
bias_normal <- mean(normal_estimates) - normal_mean
var_normal <- var(normal_estimates)
mse_normal <- bias_normal^2 + var_normal
# --- Binomial Distribution ---
binom_estimates <- replicate(n, mean(rbinom(100, size = 1, prob = binom_p)))
bias_binom <- mean(binom_estimates) - binom_p
var_binom <- var(binom_estimates)
mse_binom <- bias_binom^2 + var_binom
# --- Exponential Distribution ---
exp_estimates <- replicate(n, 1 / mean(rexp(100, rate = exp_rate)))
bias_exp <- mean(exp_estimates) - exp_rate
var_exp <- var(exp_estimates)
mse_exp <- bias_exp^2 + var_exp
# --- Display results ---
results <- data.frame(
Distribution = c("Normal", "Binomial", "Exponential"),
Bias = c(bias_normal, bias_binom, bias_exp),
Variance = c(var_normal, var_binom, var_exp),
MSE = c(mse_normal, mse_binom, mse_exp)
)
print(results)
# --- Plot histograms ---
par(mfrow = c(1, 3))
hist(normal_estimates, main = "Normal MLE", xlab = "Mean Estimates")
abline(v = normal_mean, col = "red", lwd = 2)
hist(binom_estimates, main = "Binomial MLE", xlab = "Probability Estimates")
abline(v = binom_p, col = "red", lwd = 2)
hist(exp_estimates, main = "Exponential MLE", xlab = "Rate Estimates")
abline(v = exp_rate, col = "red", lwd = 2)
