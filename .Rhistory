# Question 1(i): Simulate 10,000 sample means and compute bias
set.seed(123)          # ensures reproducibility
mu <- 20               # true mean
sigma <- 5             # true standard deviation
n <- 70                # sample size
num_sim <- 10000       # number of simulations
# Generate 10,000 sample means
sample_means <- replicate(num_sim, mean(rnorm(n, mean = mu, sd = sigma)))
# Calculate bias
bias <- mean(sample_means) - mu
cat("Bias of sample mean estimator:", bias, "\n")
# Question 1(ii): Demonstrate consistency of the sample mean
set.seed(123)
mu <- 20
sigma <- 5
num_sim <- 10000
# Different sample sizes
sample_sizes <- c(10, 50, 100, 250, 500, 750, 1000)
# Vectors to store results
mean_estimates <- numeric(length(sample_sizes))
sd_estimates <- numeric(length(sample_sizes))
# Loop through sample sizes
for (i in seq_along(sample_sizes)) {
n_i <- sample_sizes[i]
means_i <- replicate(num_sim, mean(rnorm(n_i, mean = mu, sd = sigma)))
mean_estimates[i] <- mean(means_i)
sd_estimates[i] <- sd(means_i)
}
# Plot mean estimates with ±2 SD error bars
plot(sample_sizes, mean_estimates, type = "b", pch = 19,
xlab = "Sample Size (n)", ylab = "Mean Estimate",
main = "Consistency of Sample Mean")
arrows(sample_sizes, mean_estimates - 2 * sd_estimates,
sample_sizes, mean_estimates + 2 * sd_estimates,
angle = 90, code = 3, length = 0.05, col = "blue")
abline(h = mu, col = "red", lty = 2)
